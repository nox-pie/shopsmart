    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "jest": "^29.7.0",
    "jest-junit": "^17.0.0",
    "nodemon": "^3.1.0",
    "prettier": "^3.8.1",
    "supertest": "^6.3.4"
  }
